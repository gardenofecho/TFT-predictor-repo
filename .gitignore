# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
bin/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# =======================================================================
# 💻 VIRTUAL ENVIRONMENTS (Prevents uploading thousands of dependencies)
# =======================================================================
.venv/
venv/
ENV/
env/
ActivePython-*/

# =======================================================================
# 📓 JUPYTER NOTEBOOK CACHES & SYSTEM GARBAGE
# =======================================================================
.ipynb_checkpoints/
.DS_Store
Thumbs.db

